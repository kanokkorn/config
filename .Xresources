!! -------------------- !!
!! URxvt Monochrome Dark with Shades Colorscheme
!
! To apply:
! 1. Save this content to your ~/.Xresources file.
! 2. Run: xrdb -merge ~/.Xresources
! 3. Restart URxvt or open a new terminal.

! General
! URxvt.foreground: #d0d0d0    ! Light grey for primary text
! URxvt.background: #1c1c1c    ! Very dark grey for background
! URxvt.cursorColor: #d0d0d0
! 
! ! Black (0) - Very dark grey
! URxvt.color0: #262626
! URxvt.colorBD0: #262626
! 
! ! Red (1) - Dark grey
! URxvt.color1: #505050
! URxvt.colorBD1: #505050
! 
! ! Green (2) - Medium dark grey
! URxvt.color2: #606060
! URxvt.colorBD2: #606060
! 
! ! Yellow (3) - Medium grey
! URxvt.color3: #707070
! URxvt.colorBD3: #707070
! 
! ! Blue (4) - Medium light grey
! URxvt.color4: #808080
! URxvt.colorBD4: #808080
! 
! ! Magenta (5) - Light grey
! URxvt.color5: #909090
! URxvt.colorBD5: #909090
! 
! ! Cyan (6) - Lighter grey
! URxvt.color6: #a0a0a0
! URxvt.colorBD6: #a0a0a0
! 
! ! White (7) - Very light grey (almost white)
! URxvt.color7: #c0c0c0
! URxvt.colorBD7: #c0c0c0
! 
! ! Bright Black (8) - Slightly lighter dark grey
! URxvt.color8: #404040
! URxvt.colorBD8: #404040
! 
! ! Bright Red (9) - Slightly lighter dark grey (for consistency)
! URxvt.color9: #606060
! URxvt.colorBD9: #606060
! 
! ! Bright Green (10) - Slightly lighter medium dark grey
! URxvt.color10: #707070
! URxvt.colorBD10: #707070
! 
! ! Bright Yellow (11) - Slightly lighter medium grey
! URxvt.color11: #808080
! URxvt.colorBD11: #808080
! 
! ! Bright Blue (12) - Slightly lighter medium light grey
! URxvt.color12: #909090
! URxvt.colorBD12: #909090
! 
! ! Bright Magenta (13) - Slightly lighter light grey
! URxvt.color13: #a0a0a0
! URxvt.colorBD13: #a0a0a0
! 
! ! Bright Cyan (14) - Slightly lighter lighter grey
! URxvt.color14: #b0b0b0
! URxvt.colorBD14: #b0b0b0
! 
! ! Bright White (15) - Pure white
! URxvt.color15: #ffffff
! URxvt.colorBD15: #ffffff
