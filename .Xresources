! keymap
! *.font: xft:BlexMono Nerd Font Mono:pixelsize=14

!! xterm stuff - old one
!#ifdef xterm
!! Clipboard
!xterm*keysym.Shift-Control-V: eval:paste_clipboard
!xterm*keysym.Shift-Control-C: eval:selection_to_clipboard
!! OSC52 
!xterm*disallowedWindowOps: 20,21,SetXprop
!! xterm style
!! XTerm.tintColor:     white
!! XTerm.shading:       0
!!*.font: xft: JetBrainsMono Nerd Font Mono:pixelsize=8
!! scale fonts
!*keysym.C-S-plus: font-size:increase
!*keysym.C-KP_Add: font-size:increase
!*keysym.C-S-underscore: font-size:decrease
!*keysym.C-KP_Subtract: font-size:decrease
!*keysym.C-0: font-size:reset
!*keysym.C-KP_0: font-size:reset
!! Mikazuki
!*foreground:   #ffffff
!*background:   #171717
!*cursorColor:  #ffffff
!*color0:       #2a1d17
!*color8:       #4f362b
!*color1:       #da1657
!*color9:       #da4375
!*color2:       #3ea250
!*color10:      #6cb87a
!*color3:       #e3d33d
!*color11:      #e3da84
!*color4:       #3ea290
!*color12:      #8ca8a3
!*color5:       #ff850d
!*color13:      #ffa64f
!*color6:       #8c16da
!*color14:      #a167c7
!*color7:       #e9e9e9
!*color15:      #fdfdfd
!#endif
!! xterm stuff -- update
*.font: xft:JetBrainsMono Nerd Font Mono:pixelsize=13
! OSC52 & Window Ops
XTerm*disallowedWindowOps: 20,21,SetXprop
XTerm*selectToClipboard: true
XTerm*translations: #override \
    Shift Ctrl <Key>C: copy-selection(CLIPBOARD) \n\
    Shift Ctrl <Key>V: insert-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>plus: larger-font() \n\
    Ctrl <Key>KP_Add: larger-font() \n\
    Ctrl Shift <Key>underscore: smaller-font() \n\
    Ctrl <Key>KP_Subtract: smaller-font() \n\
    Ctrl <Key>0: set-vt-font(d)

! Rosé Pine Dark Colorscheme
XTerm*foreground:   #e0def4
XTerm*background:   #191724
XTerm*cursorColor:  #524f67

! Black
XTerm*color0:       #26233a
XTerm*color8:       #6e6a86
! Red
XTerm*color1:       #eb6f92
XTerm*color9:       #eb6f92
! Green
XTerm*color2:       #31748f
XTerm*color10:      #31748f
! Yellow
XTerm*color3:       #f6c177
XTerm*color11:      #f6c177
! Blue
XTerm*color4:       #9ccfd8
XTerm*color12:      #9ccfd8
! Magenta
XTerm*color5:       #c4a7e7
XTerm*color13:      #c4a7e7
! Cyan
XTerm*color6:       #ebbcba
XTerm*color14:      #ebbcba
! White
XTerm*color7:       #e0def4
XTerm*color15:      #e0def4

!! looks
!! URxvt*blurRadius: 10
!! URxvt.transparent:   true
!XTerm.tintColor:     white
!XTerm.shading:       0
!XTerm.font: xft:BlexMono Nerd Font Mono:pixelsize=10
!! URxvt.font: xft:Ubuntu Sans:pixelsize=16
!XTerm.scrollBar: false
!
!! scale fonts
!XTerm.keysym.C-S-plus: font-size:increase
!XTerm.keysym.C-KP_Add: font-size:increase
!XTerm.keysym.C-S-underscore: font-size:decrease
!XTerm.keysym.C-KP_Subtract: font-size:decrease
!XTerm.keysym.C-0: font-size:reset
!XTerm.keysym.C-KP_0: font-size:reset

! keymap-urxvt
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard
URxvt.iso14755: false
URxvt.iso14755_52: false

! looks
! URxvt*blurRadius: 10
! URxvt.transparent:   true
URxvt.tintColor:     white
URxvt.shading:       0
! URxvt.font: xft: Iosevka Nerd Font:pixel:size=14
! URxvt.font: xft: IosevkaTerm NFM:pixel:size=12
! URxvt.font: xft: UbuntuMono Nerd Font Mono:pixel:size=12
! URxvt.font: xft: FiraMono Nerd Font Mono:pixelsize=16
URxvt.font: xft: JetBrainsMono Nerd Font Mono:pixelsize=16
! URxvt.font: xft: ProggyClean CE Nerd Font:pixelsize=22
! URxvt.font: xft: BlexMono Nerd Font Mono:pixelsize=14

! URxvt.font: xft:Ubuntu Sans:pixelsize=16 URxvt.scrollBar: false
URxvt.letterSpace: 0

! scale fonts
URxvt.keysym.C-S-plus: font-size:increase
URxvt.keysym.C-KP_Add: font-size:increase
URxvt.keysym.C-S-underscore: font-size:decrease
URxvt.keysym.C-KP_Subtract: font-size:decrease
URxvt.keysym.C-0: font-size:reset
URxvt.keysym.C-KP_0: font-size:reset

